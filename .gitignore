.DS_Store
node_modules/
*.log
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Package manager: pnpm-lock.yaml is the lockfile of record — npm/yarn lockfiles must not coexist.
package-lock.json
yarn.lock

# Secrets
.env
.env.*
!.env.example

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Runtime artifacts — downloaded by adapters/shared/claude-hooks.cjs at
# install time (from GitHub Releases), not tracked in source.
bin/
daemon/bin/
web/dist/
desktop/dl/

# Plan working copies — the Clawket DB is the source of truth for plan
# bodies; markdown snapshots under plans/ are generated/regenerated via
# `clawket plan export` and not tracked.
plans/
