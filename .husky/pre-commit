#!/bin/sh
# Plugin shell pre-commit gate.
# Enforces invariants documented in .claude/rules/*.md and CLAUDE.md "AI 가드레일".
# Slow e2e tests live in CI — this hook stays under ~1s on staged-only diffs.

set -u
FAILED=0
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

fail() { echo "✗ $1"; FAILED=1; }

# 1. Unit tests when any tracked surface changes (adapters / tests / skills / manifests / hooks).
if echo "$STAGED" | grep -qE '^(adapters/|tests/|skills/|\.claude-plugin/|hooks/hooks\.json$|components\.json$|package\.json$|scripts/)'; then
  echo "▸ pnpm test:unit"
  pnpm -s test:unit || fail "unit tests failed (run: pnpm test:unit)"
fi

# 2. components.json drift gate — bump must arrive with COMPATIBILITY matrix update
#    (.claude/rules/components-json-cross-repo-lock-step.md).
if echo "$STAGED" | grep -qx 'components.json' && ! echo "$STAGED" | grep -qx 'docs/COMPATIBILITY.md'; then
  fail "components.json changed without docs/COMPATIBILITY.md update — see .claude/rules/components-json-cross-repo-lock-step.md"
fi

# 3. JSON validity for the 4 manifests that hooks/CLI parse at startup.
for f in .claude-plugin/plugin.json .claude-plugin/marketplace.json components.json hooks/hooks.json; do
  if echo "$STAGED" | grep -qx "$f"; then
    node -e "JSON.parse(require('fs').readFileSync('$f','utf8'))" 2>/dev/null || fail "$f is not valid JSON"
  fi
done

# 4. Adapter shim line budget — adapters/claude/*.cjs delegate to shared helpers
#    (CLAUDE.md "2-줄 shim 룰"). 5-line wrap pattern + margin = 8.
for f in $(echo "$STAGED" | grep -E '^adapters/claude/.*\.cjs$' || true); do
  [ -f "$f" ] || continue
  lines=$(wc -l <"$f" | tr -d ' ')
  [ "$lines" -le 8 ] || fail "$f exceeds shim budget ($lines lines > 8) — move logic to adapters/shared/claude-hooks.cjs"
done

# 5. Rule body budget — .claude/rules/*.md stay focused (README.md exempt).
for f in $(echo "$STAGED" | grep -E '^\.claude/rules/.*\.md$' || true); do
  [ -f "$f" ] || continue
  [ "$(basename "$f")" = "README.md" ] && continue
  lines=$(wc -l <"$f" | tr -d ' ')
  [ "$lines" -le 80 ] || fail "$f exceeds rule body budget ($lines lines > 80) — split or summarize"
done

# 6. Lockfile hygiene — pnpm is the package manager of record (package.json#packageManager).
if echo "$STAGED" | grep -qxE '(package-lock\.json|yarn\.lock)'; then
  fail "package-lock.json / yarn.lock must not be committed — use pnpm (see package.json#packageManager)"
fi

exit $FAILED
