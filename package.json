{
  "name": "clawket-plugin",
  "private": true,
  "version": "3.0.5",
  "description": "Structured task contracts for LLM coding agents — Claude Code plugin shell for Clawket (hooks + prompts + skills); delegates runtime to @clawket/{cli,daemon,web}",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "setup": "node scripts/setup.cjs",
    "dev:fresh-install": "node scripts/dev-fresh-install.cjs",
    "test": "node --test tests/*.test.cjs",
    "test:unit": "node --test tests/destructive-patterns.test.cjs tests/disabled-project-bypass.test.cjs tests/exit-plan-mode-strict.test.cjs tests/skills-integrity.test.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "compat": {
    "@clawket/cli": ">=3.0.0 <4.0.0",
    "@clawket/daemon": ">=3.0.0 <4.0.0",
    "@clawket/web": ">=3.0.0 <4.0.0",
    "@clawket/desktop": ">=3.0.0 <4.0.0"
  }
}
